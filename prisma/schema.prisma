datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  profession    String?
  profDetail    String?
  firmName      String?
  firmUrl       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  agentMode     String    @default("equilibrado")

  memberships           OrgMember[]
  accounts              Account[]
  sessions              Session[]
  auditLogs             AuditLog[]
  deliverables          Deliverable[]  @relation("DeliverableOwner")
  deliverableCreations  Deliverable[]  @relation("DeliverableCreatedBy")
  deliverableUpdates    Deliverable[]  @relation("DeliverableUpdatedBy")
  agentMessages         AgentMessage[]
  projectMembers        ProjectMember[]
  notifications         Notification[]
  projectNotes          ProjectNote[]
  minutas               ProcessedMinuta[]
  invitationsSent       Invitation[]   @relation("InvitationsSent")
  dailySummaries        UserDailySummary[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrgMember[]
  projects    Project[]
  invitations Invitation[]
}

model OrgMember {
  id                String   @id @default(cuid())
  userId            String
  organizationId    String
  role              String   @default("member")
  canDeleteProjects Boolean  @default(false)
  joinedAt          DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Project {
  id                String    @id @default(cuid())
  organizationId    String
  title             String
  type              String
  status            String    @default("ok")
  startDate         DateTime?
  endDate           DateTime?
  nextPaymentAmount String?
  nextPaymentStatus String?
  budget            Float?
  billedAmount      Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id])
  members        ProjectMember[]
  deliverables   Deliverable[]
  ganttRows      GanttRow[]
  agentMessages  AgentMessage[]
  auditLogs      AuditLog[]
  notes          ProjectNote[]
  minutas        ProcessedMinuta[]
  packages       DeliverablePackage[]
  risks          ProjectRisk[]
  kpis           ProjectKPI[]
  reports        ProcessedReport[]

  @@index([organizationId])
}

model ProjectMember {
  id         String  @id @default(cuid())
  projectId  String
  userId     String?
  name       String
  initials   String
  color      String
  role       String
  isExternal Boolean @default(false)

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])
  invitation Invitation?

  @@unique([projectId, userId])
}

model Deliverable {
  id        String    @id @default(cuid())
  projectId String
  name      String
  status    String    @default("warn")
  meta      String?
  ownerId   String?
  ownerName String?
  dueDate   DateTime?
  startDate DateTime?
  priority  String    @default("media")
  notes     String?
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  createdById   String?
  createdByName String?
  updatedById   String?
  updatedByName String?

  packageId  String?

  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  package    DeliverablePackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  owner      User?               @relation("DeliverableOwner", fields: [ownerId], references: [id])
  createdBy  User?               @relation("DeliverableCreatedBy", fields: [createdById], references: [id])
  updatedBy  User?               @relation("DeliverableUpdatedBy", fields: [updatedById], references: [id])
  auditLogs  AuditLog[]
  blockedBy  DeliverableDependency[] @relation("DependencyBlocked")
  blocks     DeliverableDependency[] @relation("DependencyBlocker")

  @@index([projectId])
  @@index([ownerId])
  @@index([dueDate])
  @@index([packageId])
}

model DeliverableDependency {
  id        String @id @default(cuid())
  blockerId String
  blockedId String

  blocker   Deliverable @relation("DependencyBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Deliverable @relation("DependencyBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model GanttRow {
  id        String @id @default(cuid())
  projectId String
  label     String
  ownerName String
  start     Int
  duration  Int
  status    String @default("prog")
  order     Int    @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeliverablePackage {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables Deliverable[]
  milestones   Milestone[]

  @@index([projectId])
}

model Milestone {
  id        String   @id @default(cuid())
  packageId String
  projectId String
  type      String   // 'pre-entrega' | 'final'
  date      DateTime
  label     String?
  createdAt DateTime @default(now())

  package DeliverablePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([projectId])
  @@index([date])
}

model AgentMessage {
  id          String   @id @default(cuid())
  projectId   String?
  userId      String?
  role        String
  content     String
  cardType    String?
  actions     Json?
  dismissed     Boolean  @default(false)
  dismissReason String?
  dismissNote   String?
  executed      Boolean  @default(false)
  undone      Boolean  @default(false)
  beforeState Json?
  reasoning   String?
  scope       String?  // 'project' | 'portfolio' — null means project (backward compat)
  createdAt   DateTime @default(now())

  project   Project? @relation(fields: [projectId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  projectId     String?
  deliverableId String?
  action        String
  entity        String
  entityId      String
  entityName    String?
  oldValue      Json?
  newValue      Json?
  createdAt     DateTime @default(now())

  user          User         @relation(fields: [userId], references: [id])
  project       Project?     @relation(fields: [projectId], references: [id])
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  projectId String?
  entityId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserDailySummary {
  id        String   @id @default(cuid())
  userId    String
  date      String   // "YYYY-MM-DD" — enforces one per user per day
  content   String
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProcessedMinuta {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  title       String
  inputText   String
  summary     String
  actionsJson String
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([projectId])
}

model ProjectRisk {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  probability String   @default("medium")  // low | medium | high
  impact      String   @default("medium")  // low | medium | high
  status      String   @default("open")    // open | mitigated | closed
  mitigation  String?
  ownerName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectKPI {
  id        String   @id @default(cuid())
  projectId String
  title     String
  target    Float
  current   Float    @default(0)
  unit      String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProcessedReport {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  content     String   @db.Text
  generatedAt DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Invitation {
  id              String    @id @default(cuid())
  email           String
  organizationId  String
  projectId       String?
  projectMemberId String?   @unique
  orgRole         String    @default("member")
  projectRole     String?
  token           String    @unique @default(cuid())
  expiresAt       DateTime
  acceptedAt      DateTime?
  invitedById     String
  createdAt       DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy     User          @relation("InvitationsSent", fields: [invitedById], references: [id])
  projectMember ProjectMember? @relation(fields: [projectMemberId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
